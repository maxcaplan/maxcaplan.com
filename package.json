{
  "name": "maxcaplan-com",
  "type": "module",
  "version": "0.0.1",
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.28.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro check && vitest run && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest",
    "lint:scss": "stylelint \"./src/**/*.{astro,scss}\" --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/preact": "^5.1.1",
    "astro": "^6.1.4",
    "preact": "^10.29.1",
    "maxcaplan-icons": "workspace:*"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "sass-embedded": "^1.99.0",
    "stylelint": "^17.6.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recommended-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "react": "npm:@preact/compat@latest",
    "react-dom": "npm:@preact/compat@latest"
  },
  "lint-staged": {
    "**/*.{astro,scss}": "stylelint --fix",
    "**/*": "prettier --write --ignore-unknown"
  }
}
