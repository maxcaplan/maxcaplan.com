{
  "name": "maxcaplan-icons",
  "version": "0.1.0",
  "description": "Icon library for maxcaplan.com",
  "keywords": [
    "icons"
  ],
  "license": "GPL-3.0-or-later",
  "author": "Max Caplan",
  "engines": {
    "node": ">=24"
  },
  "type": "commonjs",
  "source": "src/index.ts",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/types.d.ts",
  "scripts": {
    "generate:icons": "node -r @swc-node/register ./scripts/generate-icons.ts",
    "watch": "parcel watch",
    "prebuild": "npm run generate:icons",
    "build": "parcel build"
  },
  "dependencies": {
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@parcel/packager-ts": "2.16.4",
    "@parcel/transformer-typescript-types": "2.16.4",
    "@swc-node/register": "^1.11.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "isomorphic-dompurify": "^3.8.0",
    "parcel": "^2.16.4",
    "typescript": "^6.0.2"
  }
}
